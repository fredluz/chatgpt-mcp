{
  "name": "@guilhermesilveira/chatgpt-mcp",
  "version": "0.1.1",
  "description": "Local MCP server that drives ChatGPT web via patchright (persistent login, CDP-shared session).",
  "type": "module",
  "bin": {
    "chatgpt-mcp": "./cli.mjs"
  },
  "files": [
    "*.mjs",
    "selectors.json",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guilhermesilveira/chatgpt-mcp.git"
  },
  "homepage": "https://github.com/guilhermesilveira/chatgpt-mcp",
  "bugs": {
    "url": "https://github.com/guilhermesilveira/chatgpt-mcp/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "chatgpt",
    "mcp",
    "playwright",
    "patchright",
    "automation",
    "claude-code"
  ],
  "scripts": {
    "launch": "node cli.mjs launch",
    "daemon": "node cli.mjs daemon",
    "mcp": "node cli.mjs server",
    "http": "node cli.mjs http",
    "check": "node cli.mjs check",
    "test": "node --test 'tests/*.test.mjs'"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "patchright": "^1.59.4"
  }
}
