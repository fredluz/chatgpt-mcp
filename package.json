{
  "name": "@fredluz/exocortex-chatgpt-connector",
  "version": "0.1.1",
  "description": "Async multi-agent orchestration layer over ChatGPT Pro with MCP/HTTP/CLI surfaces and image download pipeline.",
  "type": "module",
  "bin": {
    "exocortex-chatgpt": "./cli.mjs",
    "chatgpt-mcp": "./cli.mjs"
  },
  "files": [
    "*.mjs",
    "scripts/camoufox-bootstrap.mjs",
    "selectors.json",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fredluz/exocortex-chatgpt-connector.git"
  },
  "homepage": "https://github.com/fredluz/exocortex-chatgpt-connector",
  "bugs": {
    "url": "https://github.com/fredluz/exocortex-chatgpt-connector/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "chatgpt",
    "mcp",
    "playwright",
    "patchright",
    "automation",
    "claude-code"
  ],
  "scripts": {
    "launch": "node cli.mjs launch",
    "daemon": "node cli.mjs daemon",
    "mcp": "node cli.mjs server",
    "http": "node cli.mjs http",
    "check": "node cli.mjs check",
    "camoufox:fetch": "npx camoufox fetch",
    "postinstall": "node scripts/camoufox-bootstrap.mjs",
    "test": "node --test 'tests/*.test.mjs'"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "camoufox": "^0.1.19",
    "patchright": "^1.59.4"
  }
}
